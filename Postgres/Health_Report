\echo ‘’
\echo ‘— 13.1  Installed Extensions —’
SELECT
extname,
extversion,
n.nspname                                           AS schema
FROM pg_extension e
JOIN pg_namespace n ON n.oid = e.extnamespace
ORDER BY extname;

\echo ‘’
\echo ‘— 13.2  Available Extensions —’
SELECT
name,
default_version,
installed_version,
comment
FROM pg_available_extensions
ORDER BY name;

