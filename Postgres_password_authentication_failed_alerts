#!/bin/bash

set -euo pipefail  # Exit on error, undefined vars, pipe failures

CLUSTERS=("cluster-1" "cluster-2" "cluster-3")
REGION="us-east-1"
ACCOUNT_ID="123456789012"
SNS_TOPIC_ARN="arn:aws:sns:${REGION}:${ACCOUNT_ID}:aurora-auth-failure-alerts"
METRIC_NAMESPACE="RDS/AuroraPostgres"
THRESHOLD=5
PERIOD=300
EVALUATION_PERIODS=1

# Validate SNS topic exists before processing any cluster
echo "Validating SNS topic..."
aws sns get-topic-attributes \
  --topic-arn "$SNS_TOPIC_ARN" \
  --region "$REGION" > /dev/null

if [ $? -ne 0 ]; then
  echo "ERROR: SNS topic not found or inaccessible: $SNS_TOPIC_ARN"
  exit 1
fi
echo "SNS topic validated."
echo "---"

SUCCESS_COUNT=0
SKIP_COUNT=0
FAIL_COUNT=0

for CLUSTER_ID in "${CLUSTERS[@]}"; do
  LOG_GROUP="/aws/rds/cluster/${CLUSTER_ID}/postgresql"

  # Unique metric name and filter name per cluster to avoid metric data collision
  METRIC_NAME="PasswordAuthFailureCount-${CLUSTER_ID}"
  FILTER_NAME="PasswordAuthFailures-${CLUSTER_ID}"
  ALARM_NAME="AuroraPostgres-PasswordAuthFailures-${CLUSTER_ID}"

  echo "Processing: $CLUSTER_ID"

  # Verify log group exists before proceeding
  LOG_GROUP_EXISTS=$(aws logs describe-log-groups \
    --log-group-name-prefix "$LOG_GROUP" \
    --region "$REGION" \
    --query "logGroups[?logGroupName=='${LOG_GROUP}'].logGroupName" \
    --output text)

  if [ -z "$LOG_GROUP_EXISTS" ]; then
    echo "  WARNING: Log group $LOG_GROUP not found, skipping $CLUSTER_ID"
    SKIP_COUNT=$((SKIP_COUNT + 1))
    continue
  fi

  echo "  Log group found: $LOG_GROUP"

  # Check if metric filter already exists to avoid silent overwrites
  FILTER_EXISTS=$(aws logs describe-metric-filters \
    --log-group-name "$LOG_GROUP" \
    --filter-name-prefix "$FILTER_NAME" \
    --region "$REGION" \
    --query "metricFilters[?filterName=='${FILTER_NAME}'].filterName" \
    --output text)

  if [ -n "$FILTER_EXISTS" ]; then
    echo "  WARNING: Metric filter '$FILTER_NAME' already exists on $LOG_GROUP — it will be overwritten"
  fi

  # Create metric filter
  aws logs put-metric-filter \
    --log-group-name "$LOG_GROUP" \
    --filter-name "$FILTER_NAME" \
    --filter-pattern '"password authentication failed"' \
    --metric-transformations \
      metricName=${METRIC_NAME},metricNamespace=${METRIC_NAMESPACE},metricValue=1,defaultValue=0,unit=Count \
    --region "$REGION"

  if [ $? -eq 0 ]; then
    echo "  Metric filter created: $FILTER_NAME"
  else
    echo "  ERROR: Failed to create metric filter for $CLUSTER_ID"
    FAIL_COUNT=$((FAIL_COUNT + 1))
    continue
  fi

  # Check if alarm already exists
  ALARM_EXISTS=$(aws cloudwatch describe-alarms \
    --alarm-names "$ALARM_NAME" \
    --region "$REGION" \
    --query "MetricAlarms[?AlarmName=='${ALARM_NAME}'].AlarmName" \
    --output text)

  if [ -n "$ALARM_EXISTS" ]; then
    echo "  WARNING: Alarm '$ALARM_NAME' already exists — it will be overwritten"
  fi

  # Create CloudWatch alarm
  aws cloudwatch put-metric-alarm \
    --alarm-name "$ALARM_NAME" \
    --alarm-description "Password authentication failures on Aurora cluster ${CLUSTER_ID}" \
    --namespace "$METRIC_NAMESPACE" \
    --metric-name "$METRIC_NAME" \
    --statistic "Sum" \
    --period $PERIOD \
    --evaluation-periods $EVALUATION_PERIODS \
    --threshold $THRESHOLD \
    --comparison-operator "GreaterThanOrEqualToThreshold" \
    --treat-missing-data "notBreaching" \
    --alarm-actions "$SNS_TOPIC_ARN" \
    --ok-actions "$SNS_TOPIC_ARN" \
    --region "$REGION"

  if [ $? -eq 0 ]; then
    echo "  Alarm created: $ALARM_NAME"
    SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
  else
    echo "  ERROR: Failed to create alarm for $CLUSTER_ID"
    FAIL_COUNT=$((FAIL_COUNT + 1))
  fi

  echo "---"
done

echo ""
echo "Summary:"
echo "  Successful : $SUCCESS_COUNT"
echo "  Skipped    : $SKIP_COUNT"
echo "  Failed     : $FAIL_COUNT"
